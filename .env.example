# ═══════════════════════════════════════════════════════════════════════
# Regular Investor Ecosystem — environment for the root docker-compose.yml
# Copy to `.env` and fill in real values. Never commit `.env`.
# ═══════════════════════════════════════════════════════════════════════

# ── Shared auth secret (CRITICAL) ────────────────────────────────────
# USER_SECRET is the HMAC key for user/terminal session tokens. The terminal
# backend's RI_USER_SECRET is set from this same value in compose, so tokens
# verify across services. Use a random 32+ char string.
USER_SECRET=change_me_to_a_random_32_char_string

# Admin panel secret + initial admin password
ADMIN_SECRET=change_this_secret_to_32chars!!
ADMIN_PASSWORD=admin123

# ── Database ─────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=regular_investor
DB_USER=ri_user
DB_PASSWORD=your_strong_password_here

# ── Public URLs ──────────────────────────────────────────────────────
# APP_URL      = public URL of Regular Investor (used for OAuth redirect and
#                baked into the terminal frontend for cross-origin API calls).
# TERMINAL_URL = public URL of the R-IDX Terminal (used for the access-token
#                redirect and the terminal backend CORS allow-list).
APP_URL=http://localhost:3000
TERMINAL_URL=http://localhost:3001

# ── Google OAuth (optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI News Sentiment (terminal backend) ─────────────────────────────
# Free LLM keys used by the terminal's news-sentiment agents. Passed into the
# terminal-backend container via docker-compose. Leave empty to disable
# sentiment (the NEWS tab still works, just without badges).
#   Gemini key: https://aistudio.google.com/app/apikey
#   Groq key:   https://console.groq.com/keys
#   HF token:   https://huggingface.co/settings/tokens
GEMINI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
# Providers to combine into a consensus (comma-separated): gemini, groq, hf1, hf2, hf3.
SENTIMENT_PROVIDERS=gemini,groq,hf1,hf2,hf3

# ── Telegram buzz alerts ─────────────────────────────────────────
# Pushes a message to a Telegram group whenever a NEW (or updated) buzz ticker
# appears. Leave token/chat id empty to disable. Create a bot via @BotFather to
# get the token, add it to your group, then read the group chat id (negative,
# e.g. -1001234567890) from https://api.telegram.org/bot<TOKEN>/getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BUZZ_ALERT_ENABLED=true
# How often to check for new buzz (seconds). 900 = 15 min, matches the warmer.
BUZZ_ALERT_INTERVAL=900
# Ignore tickers mentioned fewer times than this (noise filter).
BUZZ_ALERT_MIN_MENTIONS=2
# Only consider the top-N buzz tickers each cycle.
BUZZ_ALERT_TOP_N=10
# Cap messages sent per cycle (anti-spam).
BUZZ_ALERT_MAX_PER_CYCLE=5
# Public site URL used in the Telegram alert's "Buka Regular Investor" link.
PUBLIC_SITE_URL=https://regular-investor.com