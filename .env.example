# ═══════════════════════════════════════════════════════════════════════
# Regular Investor Ecosystem — environment for the root docker-compose.yml
# Copy to `.env` and fill in real values. Never commit `.env`.
# ═══════════════════════════════════════════════════════════════════════

# ── Shared auth secret (CRITICAL) ────────────────────────────────────
# USER_SECRET is the HMAC key for user/terminal session tokens. The terminal
# backend's RI_USER_SECRET is set from this same value in compose, so tokens
# verify across services. Use a random 32+ char string.
USER_SECRET=change_me_to_a_random_32_char_string

# Admin panel secret + initial admin password
ADMIN_SECRET=change_this_secret_to_32chars!!
ADMIN_PASSWORD=admin123

# ── Database ─────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=regular_investor
DB_USER=ri_user
DB_PASSWORD=your_strong_password_here

# ── Public URLs ──────────────────────────────────────────────────────
# APP_URL      = public URL of Regular Investor (used for OAuth redirect and
#                baked into the terminal frontend for cross-origin API calls).
# TERMINAL_URL = public URL of the R-IDX Terminal (used for the access-token
#                redirect and the terminal backend CORS allow-list).
APP_URL=http://localhost:3000
TERMINAL_URL=http://localhost:3001

# ── Google OAuth (optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI News Sentiment (terminal backend) ─────────────────────────────
# Free LLM keys used by the terminal's news-sentiment agents. Passed into the
# terminal-backend container via docker-compose. Leave empty to disable
# sentiment (the NEWS tab still works, just without badges).
#   Gemini key: https://aistudio.google.com/app/apikey
#   Groq key:   https://console.groq.com/keys
GEMINI_API_KEY=
GROQ_API_KEY=
# Providers to combine into a consensus (comma-separated): gemini, groq.
SENTIMENT_PROVIDERS=gemini,groq
